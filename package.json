{
  "name": "dons-treasury",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite --host",
    "dev:server": "tsx watch server.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "tsc -b && vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist-server/server.js",
    "build": "npm run build:client && npm run build:server",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "docker:build": "docker build -t fiscal-navigator .",
    "docker:run": "mkdir -p data && (docker rm -f fnav >/dev/null 2>&1 || true) && docker run -d --name fnav -p 3001:3001 -v \"$PWD/data:/app/data\" fiscal-navigator && echo 'Treasury OS: http://localhost:3001'",
    "docker:start": "npm run docker:build && npm run docker:run",
    "docker:stop": "docker rm -f fnav",
    "docker:logs": "docker logs -f fnav",
    "deploy": "docker buildx build --platform linux/amd64,linux/arm64 -t dgabrielablay/fiscal-navigator:latest --push .",
    "deploy:single": "docker build -t dgabrielablay/fiscal-navigator:latest . && docker push dgabrielablay/fiscal-navigator:latest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.11",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.5"
  }
}
